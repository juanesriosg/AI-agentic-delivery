    "spec_autostart_legacy": ".github/workflows/agentic-spec-autostart.yml",
    "night_cloud_manual_only": ".github/workflows/agentic-night-cloud.yml",
    "default_codex_model": "gpt-5.5",
    "default_reasoning_effort": "xhigh",
    "local_first_update": ".ai/docs/reference/LOCAL_FIRST_CODEX_RUNTIME_V14.md",
    "self_improvement": ".github/workflows/agentic-self-improvement.yml",
    "skill_improvement_gate": ".github/workflows/agentic-skill-improvement-gate.yml"
  },
  "self_improvement": {
    "enabled": true,
    "policy": ".ai/specs/self-improvement-policy.yml",
    "skill": ".ai/skills/self-improvement-loop.skill.md",
    "feedback_capture_script": ".ai/scripts/capture_agent_feedback.py",
    "loop_script": ".ai/scripts/skill_improvement_loop.py",
    "eval_runner": ".ai/scripts/skill_eval_runner.py",
    "guardrails": ".ai/scripts/skill_guardrails.py",
    "feedback_jsonl": ".agent/feedback/feedback.jsonl",
    "committed_feedback_dir": "docs/agentic-feedback",
    "proposal_dir": "docs/agentic-self-improvement/proposals",
