{
  "version": "15.0-local-first-codex-55-xhigh-self-improving",
  "manager": {
    "github_user": "juanesriosg",
    "timezone": "America/Bogota",
    "work_start_local": "08:00",
    "work_end_local": "18:00"
  },
  "repository": {
    "remote": "origin",
    "default_base_branch": "main",
    "allow_default_branch_fallback": true,
    "state_dir": ".agent/state",
    "run_dir": ".agent/runs",
    "worktree_dir": ".agent/worktrees",
    "evidence_dir": "docs/agentic-evidence",
    "commit_evidence": true,
    "retry_failed_specs": true,
    "skip_specs_with_existing_agent_branch": false
  },
  "spec_detection": {
    "watched_branches": [
      "dev/*",
      "develop",
      "spec/*",
      "chatgpt/*",
      "ai-spec/*",
      "feature/spec/*"
    ],
    "spec_file_patterns": [
      "specs/**/*.md",
      "specs/**/*.yaml",
      "specs/**/*.yml",
      ".ai/inbox/specs/**/*.md",
      ".ai/inbox/specs/**/*.yaml",
      ".codex/specs/**/*.md",
      "docs/specs/**/*.md",
      "requirements/specs/**/*.md"
    ],
    "ignore_file_patterns": [
      "**/README.md",
      "**/.archived/**",
      "**/drafts/**",
      "**/_TEMPLATE.*",
      "**/*.template.*",
      "**/_TEMPLATE*",
      "**/template.*",
      "**/_template*",
      "**/*_TEMPLATE*",
      "**/*.example.*",
      "**/example-*",
      ".ai/examples/**",
      "**/examples/**"
    ],
    "ready_statuses": [
      "ready_for_agents",
      "ready",
      "approved",
      "implementation_ready"
    ],
    "process_specs_without_status": false,
    "validate_before_implementation": true
  },
  "codex": {
    "binary": "codex",
    "sandbox": "workspace-write",
    "json_events": true,
    "ignore_user_config": false,
    "allow_missing_codex_for_dry_run": true,
    "env_api_key_names": [
      "CODEX_API_KEY",
      "OPENAI_API_KEY"
    ],
    "allow_missing_codex": false,
    "allow_prompt_only_when_codex_missing": false,
    "model": "gpt-5.5",
    "reasoning_effort": "xhigh",
    "reasoning_summary": "concise",
    "verbosity": "high",
    "cloud_requires_explicit_request": true,
    "default_runtime_mode": "local",
    "allow_cloud_mode_by_default": false,
    "explicit_cloud_env_var": "AGENTIC_EXPLICIT_CLOUD",
    "model_fallback": "gpt-5.4",
    "model_reasoning_effort": "xhigh",
    "requested_reasoning_profile": "extra_high",
    "note": "Local Codex agentic SDLC runs use gpt-5.5 with model_reasoning_effort=xhigh. Cloud mode is blocked unless explicitly requested.",
    "local_first": true,
    "cloud_execution_requires_explicit_opt_in": true,
    "cloud_opt_in_env_var": "AGENTIC_EXPLICIT_CLOUD",
    "cloud_opt_in_value": "true",
    "block_implicit_cloud_runs": true,
    "model_env_var": "AGENTIC_CODEX_MODEL",
    "reasoning_effort_env_var": "AGENTIC_CODEX_REASONING_EFFORT"
  },
  "execution": {
    "max_specs_per_run": 2,
    "max_tasks_per_spec": 8,
    "max_agent_turns_per_task": 12,
    "one_responsibility_per_pr": true,
    "continue_when_clarification_exists": true,
    "stop_on_high_risk_without_approval": true,
    "default_task_domains": [
      "product",
      "architecture",
      "frontend",
      "backend",
      "database",
      "cloud",
      "security",
      "qa",
      "pm",
      "release"
    ],
    "retry_failed_specs": true,
    "default_mode": "local",
    "cloud_requires_explicit_request": true,
    "cloud_only_when_explicitly_requested": true
  },
  "branching": {
    "implementation_branch_prefix": "ai",
    "base_pr_to_source_spec_branch": false,
    "qa_user_branch_prefix": "qa-user",
    "prod_ready_branch_prefix": "prod-ready",
    "push_tasks_to_source_spec_branch": true,
    "create_task_prs": false,
    "create_final_pr_from_spec_branch": true,
    "final_pr_base_branch": "main"
  },
  "pr_policy": {
    "max_files_changed": 35,
    "max_lines_changed": 1200,
    "require_one_responsibility": true,
    "require_tests": true,
    "require_agent_log": true,
    "require_screenshots_for_ui_changes": true,
    "require_integration_tests_for_api_changes": true,
    "require_e2e_tests_for_user_flows": true,
    "require_terraform_for_new_aws_components": true,
    "tag_manager_in_pr": true,
    "open_as_draft": true,
    "block_placeholder_evidence": true,
    "block_evidence_only_pr": true,
    "allow_multi_domain_pr": false,
    "require_codex_ai_review": true,
    "required_codex_status_check": "Agentic Codex PR Review / codex_review_gate",
    "post_codex_review_request_comment": true,
    "human_approval_requires_codex_pass": true,
    "require_branch_conflict_guard": true,
    "required_branch_conflict_status_check": "Agentic branch conflict guard / branch_conflict_guard",
    "require_design_gate": true,
    "require_layer_gate": true,
    "require_db_api_front_dependency_order": true,
    "unit_tests_are_not_enough": true,
    "require_layered_test_matrix": true,
    "require_skill_improvement_gate_for_skill_changes": true,
    "required_skill_improvement_status_check": "Agentic skill improvement gate / skill_improvement_gate"
  },
  "deployment": {
    "dev_deploy_allowed": true,
    "qa_deploy_requires_qa_pass": true,
    "staging_requires_pm_and_qa_pass": true,
    "production_requires_human_review": true,
    "all_aws_changes_must_use_terraform": true,
    "allowed_deploy_entrypoints": [
      ".github/workflows/*.yml",
      ".github/workflows/*.yaml",
      "infra/terraform/**",
      "terraform/**",
      "scripts/deploy/**"
    ]
  },
  "agents": {
    "planning": "spec-task-splitter.agent.md",
    "orchestrator": "agentic-sdlc-orchestrator.agent.md",
    "dev_manager": "dev-manager-pr-governor.agent.md",
    "cloud_night": "cloud-night-worker.agent.md",
    "frontend": "frontend-engineer.agent.md",
    "backend": "backend-engineer.agent.md",
    "database": "database-engineer.agent.md",
    "cloud": "terraform-platform-engineer.agent.md",
    "security": "security-engineer.agent.md",
    "design": "ui-designer.agent.md",
    "qa": "qa-evidence-collector.agent.md",
    "pm": "product-manager-acceptance.agent.md",
    "release": "release-train-engineer.agent.md",
    "pr_docs": "pr-documentation-agent.agent.md",
    "data_feedback": "data-feedback-mining.agent.md",
    "codex_pr_reviewer": "codex-pr-reviewer.agent.md",
    "business_data_analyst": "business-data-analyst.agent.md",
    "sql_readonly_analyst": "sql-readonly-analyst.agent.md",
    "business_context_curator": "business-context-curator.agent.md",
    "branch_conflict_coordinator": "branch-conflict-coordinator.agent.md",
    "architecture_design_lead": "architecture-design-lead.agent.md",
    "data_model_architect": "data-model-architect.agent.md",
    "test_strategy_architect": "test-strategy-architect.agent.md",
    "paradigm_selection": "paradigm-selection-agent.agent.md",
    "dependency_gate_qa": "dependency-gate-qa.agent.md",
    "layer_sequencing": "layer-sequencing-orchestrator.agent.md",
    "feedback_harvester": "feedback-harvester.agent.md",
    "skill_improver": "skill-improver.agent.md",
    "eval_designer": "eval-designer.agent.md",
    "skill_improvement_reviewer": "skill-improvement-reviewer.agent.md"
  },
  "spec_templates": {
    "markdown_template": "specs/_TEMPLATE.agentic-spec.md",
    "yaml_template": "specs/_TEMPLATE.agentic-spec.yml",
    "guide": ".ai/docs/reference/SPEC_TEMPLATE_GUIDE.md",
    "validator": ".ai/scripts/validate_agentic_spec.py",
    "schema": ".ai/specs/spec-template.schema.yml"
  },
  "spec_quality": {
    "require_description": true,
    "require_business_need": true,
    "require_user_needs": true,
    "require_files_to_touch": true,
    "require_do_not_touch_paths": true,
    "require_acceptance_criteria": true,
    "require_testing_expectations": true,
    "require_definition_of_done": true,
    "require_pr_decomposition_when_multi_domain": true,
    "allow_safe_progress_with_non_blocking_clarifications": true,
    "require_design_first_blueprint": true,
    "require_data_model_or_explicit_na": true,
    "require_api_contract_or_explicit_na": true,
    "require_cloud_components_or_explicit_na": true,
    "require_layered_test_strategy": true,
    "require_paradigm_decision": true
  },
  "codex_pr_review": {
    "enabled": true,
    "required_status_check": "Agentic Codex PR Review / codex_review_gate",
    "workflow": ".github/workflows/agentic-codex-pr-review.yml",
    "request_review_workflow": ".github/workflows/agentic-codex-review-request.yml",
    "prompt": ".github/codex/prompts/pr-review.md",
    "parser": ".ai/scripts/codex_pr_review_gate.py",
    "required_secret": "OPENAI_API_KEY",
    "pass_marker": "<!-- codex-pr-review-status: PASS -->",
    "manager_override_label": "ai:codex-review-human-override"
  },
  "data_analysis": {
    "enabled": true,
    "policy": ".ai/specs/data-analysis-policy.yml",
    "business_context_policy": ".ai/specs/business-context-policy.yml",
    "context_builder": ".ai/scripts/build_business_context.py",
    "safe_sql_runner": ".ai/scripts/safe_sql_query.py",
    "required_readonly_dsn_env_var": "AGENTIC_DB_DSN_READONLY",
    "default_output_dir": ".agent/data-analysis",
    "business_context_output": "docs/agentic-business-context/context-pack.md",
    "issue_template": ".github/ISSUE_TEMPLATE/data_question.yml",
    "workflow": ".github/workflows/agentic-data-analysis-request.yml",
    "allow_mutating_sql": false,
    "allowed_sql": [
      "SELECT",
      "WITH_SELECT",
      "EXPLAIN_SELECT"
    ],
    "default_limit": 500,
    "max_limit": 5000,
    "prefer_aggregates": true,
    "redact_sensitive_columns": true,
    "raw_pii_requires_manager_approval": true
  },
  "branch_conflict": {
    "enabled": true,
    "policy": ".ai/specs/branch-conflict-policy.yml",
    "guard_script": ".ai/scripts/branch_conflict_guard.py",
    "agent": ".ai/agents/branch-conflict-coordinator.agent.md",
    "skill": ".ai/skills/branch-conflict-avoidance.skill.md",
    "default_base_branch": "main",
    "block_on_overlap": true,
    "scan_remote_branches": true,
    "write_path_leases": true,
    "commit_path_leases": true,
    "push_path_leases": true,
    "continue_with_next_task_when_blocked": true,
    "ignore_patterns": [
      "docs/agentic-evidence/**",
      "docs/agentic-path-leases/**",
      ".agent/**"
    ]
  },
  "design_first": {
    "enabled": true,
    "block_implementation_without_design": true,
    "required_sections": [
      "business need",
      "requirements",
      "design",
      "architecture",
      "data model",
      "api contract",
      "cloud",
      "testing strategy",
      "layer order",
      "paradigm",
      "acceptance criteria",
      "files to touch"
    ],
    "allow_explicit_not_applicable": true,
    "design_report_dir": ".agent/design-gates",
    "gate_script": ".ai/scripts/design_gate.py",
    "principle": "Architecture/design is the contract before implementation. Missing data/API/cloud/frontend structure is a blocker, not a coding task."
  },
  "layer_gates": {
    "enabled": true,
    "strict_db_api_front_order": true,
    "database_before_api": true,
    "api_before_frontend": true,
    "block_frontend_if_api_missing": true,
    "block_api_if_database_missing": true,
    "merge_required_for_next_layer": true,
    "allow_contract_only_parallelism": false,
    "pass_file_dir": "docs/agentic-evidence/{spec_id}/layer-gates",
    "gate_script": ".ai/scripts/layer_gate.py",
    "order": [
      "design",
      "cloud",
      "database",
      "api",
      "backend",
      "frontend",
      "qa",
      "pm",
      "release"
    ],
    "required_status_check": "Agentic design and layer gates / design_layer_gates",
    "unit_tests_are_not_completion": true
  },
  "poc_to_pr_workflow": {
    "enabled": true,
    "description": "Boss POC -> GPT Pro spec -> spec branch -> Codex agents implement -> same branch receives code -> final PR tags manager.",
    "spec_branch_prefixes": [
      "dev/",
      "spec/",
      "chatgpt/",
      "ai-spec/",
      "feature/spec/"
    ],
    "default_spec_dir": "specs",
    "final_pr_target": "main",
    "tag_manager_in_final_pr": true,
    "run_in_codex_cloud_on_push": false,
    "source_spec_branch_is_integration_branch": true,
    "one_responsibility_task_commits": true,
    "final_human_review_pr": true,
    "default_runtime_mode": "local",
    "cloud_requires_explicit_request": true,
    "cloud_mode_requires": "manual workflow_dispatch mode=cloud with allow_cloud=true, --allow-cloud, or AGENTIC_EXPLICIT_CLOUD=true",
    "default_mode": "local",
    "cloud_only_when_explicitly_stated": true,
    "cloud_requires_env_var": "AGENTIC_EXPLICIT_CLOUD",
    "cloud_requires_value": "true"
  },
  "automation_workflows": {
