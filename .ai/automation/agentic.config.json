    "minimum_eval_cases": 5,
    "default_runtime_mode": "local",
    "cloud_only_when_explicitly_stated": true,
    "runtime_agents_may_modify_skills": false,
    "skill_improver_may_propose_diffs": true,
    "human_review_required": true,
